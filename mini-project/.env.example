# ==============================================
# GOLD Eyes — Environment Variables
# ==============================================
# Copy this file to .env.local and fill in your API keys.
# The app works without API keys using simulated/fallback data.

# Gold Price API (https://www.goldapi.io/)
GOLD_API_KEY=

# Metals.dev API - Fallback gold price (https://metals.dev/)
METALS_DEV_API_KEY=

# News API (https://newsapi.org/)
NEWS_API_KEY=

# Google Maps Embed API (for retail directory maps)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Optional: Supabase (for persistent alerts & auth)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ==============================================
# Gold AI Signal — Technical Analysis
# ==============================================
# Market data for signal calculations (choose one)
TWELVE_DATA_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Python FastAPI backend (optional — falls back to TypeScript engine)
PYTHON_BACKEND_URL=http://localhost:8000

# Alert: Telegram Bot
# 1. Create a bot via @BotFather → get token
# 2. Message @userinfobot → get chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Alert: Email via SMTP
SMTP_HOST=smtp.gmail.com
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=
